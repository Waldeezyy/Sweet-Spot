# Database (Railway Postgres plugin auto-injects this)
DATABASE_URL=postgresql://user:password@localhost:5432/sweetspot

# Site URL (Railway *.up.railway.app or custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000

# Admin login (set in Railway — never commit real passwords)
ADMIN_EMAIL=bssweetstop25@gmail.com
ADMIN_PASSWORD=choose-a-strong-password-here

# Email for order notifications (Resend — optional until you want emails)
RESEND_API_KEY=
EMAIL_FROM="B's Sweet Spot <onboarding@resend.dev>"

# Stripe (https://stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Uploads (Railway: mount a volume at /app/public/uploads and optionally set UPLOAD_DIR)
# UPLOAD_DIR=/app/public/uploads
# UPLOAD_MAX_EDGE=1920
# UPLOAD_WEBP_QUALITY=82
