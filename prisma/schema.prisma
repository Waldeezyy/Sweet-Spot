generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderType {
  STANDARD
  SEMI_CUSTOM
}

enum OrderStatus {
  PENDING_DEPOSIT
  PENDING_REVIEW
  CONFIRMED
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  QUOTE_REQUESTED
  QUOTE_SENT
  PENDING_DEPOSIT
  CONVERTED
  DECLINED
}
enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum CategoryFormType {
  SIMPLE
  CUPCAKE
  ROUND_CAKE
  SHEET_CAKE
  PARTY_PACKAGE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  formType  CategoryFormType @default(SIMPLE)
  isActive  Boolean          @default(true)
  sortOrder Int              @default(0)
  products  Product[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Product {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  description     String      @db.Text
  basePriceCents  Int
  isStartingPrice Boolean     @default(false)
  orderType       OrderType   @default(STANDARD)
  imageUrl        String?
  isActive        Boolean     @default(true)
  sortOrder       Int         @default(0)
  allowFlavor     Boolean     @default(true)
  allowTopping    Boolean     @default(true)
  allowFrosting   Boolean     @default(true)
  allowWriting    Boolean     @default(true)
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model GalleryImage {
  id         String   @id @default(cuid())
  url        String
  alt        String?
  isFeatured Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  author    String
  rating    Int
  text      String   @db.Text
  itemName  String?
  photos    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShopSettings {
  id                  Int      @id @default(1)
  businessName        String   @default("B's Sweet Spot")
  tagline             String?
  aboutText           String   @db.Text
  contactEmail        String
  location            String   @default("Dimondale, Michigan")
  orderMinimumCents   Int      @default(2500)
  depositPercent      Int      @default(25)
  fullPaymentThresholdCents Int @default(7500)
  leadTimeDays        Int      @default(2)
  deliveryRadiusMiles Int      @default(12)
  deliveryFeeCents    Int      @default(0)
  pickupInstructions  String   @db.Text
  deliveryNote        String   @db.Text
  allergyNote         String   @db.Text
  updatedAt           DateTime @updatedAt
}

model FlavorOption {
  id            String   @id @default(cuid())
  name          String   @unique
  flavorGroup   String?
  categorySlugs String[] @default([])
  productSlugs  String[] @default([])
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
}

model AddOnOption {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  priceCents    Int
  priceLabel    String
  categorySlugs String[] @default([])
  productSlugs  String[] @default([])
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TreatTypeOption {
  id            String   @id @default(cuid())
  name          String   @unique
  categorySlugs String[] @default([])
  productSlugs  String[] @default([])
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
}

model ToppingOption {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
}

model Availability {
  id         String   @id @default(cuid())
  date       DateTime @unique @db.Date
  isBlocked  Boolean  @default(false)
  maxOrders  Int      @default(10)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id                  String          @id @default(cuid())
  orderNumber         String          @unique
  trackingToken       String          @unique @default(cuid())
  status              OrderStatus     @default(PENDING_DEPOSIT)
  customerName        String
  customerEmail       String
  customerPhone       String?
  fulfillmentType     FulfillmentType
  deliveryAddress     String?
  scheduledDate       DateTime        @db.Date
  subtotalCents       Int
  deliveryFeeCents    Int             @default(0)
  totalCents          Int
  finalTotalCents     Int?
  depositCents        Int
  balanceDueCents     Int
  paidInFull          Boolean         @default(false)
  depositPaid         Boolean         @default(false)
  stripeSessionId     String?
  stripePaymentIntent String?
  isRush              Boolean         @default(false)
  paymentToken        String?         @unique
  adminNotes          String?         @db.Text
  estimatedReadyAt    DateTime?
  items               OrderItem[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model OrderItem {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId         String?
  productName       String
  productSlug       String?
  unitPriceCents    Int
  quantity          Int      @default(1)
  flavor            String?
  frosting          String?
  toppings          String?
  writing           String?
  designNotes       String?  @db.Text
  allergyNotes      String?  @db.Text
  inspirationPhotos String[] @default([])
}

model QuoteRequest {
  id                String      @id @default(cuid())
  status            QuoteStatus @default(QUOTE_REQUESTED)
  customerName      String
  customerEmail     String
  customerPhone     String?
  occasion          String
  scheduledDate     DateTime    @db.Date
  servings          Int?
  description       String      @db.Text
  dietaryNotes      String?
  budgetRange       String?
  inspirationPhotos String[]    @default([])
  quotedPriceCents  Int?
  quoteMessage      String?     @db.Text
  declineMessage    String?     @db.Text
  convertedOrderId  String?
  paymentToken      String?     @unique
  offlinePaymentNote String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}
